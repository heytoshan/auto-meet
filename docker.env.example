# Database Configuration
DATABASE_URL=postgresql://automeet_user:automeet_password@postgres:5432/automeet

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Google Gemini API Key
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail Credentials for Meeting Bot
GMAIL_USER_EMAIL=your_gmail@gmail.com
GMAIL_USER_PASSWORD=your_app_password_here

# Deepgram API Key for Speech-to-Text
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Meeting Configuration
DURATION_IN_MINUTES=15
MAX_WAITING_TIME_IN_MINUTES=5

# Backend URL (for meeting handler)
BACKEND_URL=http://backend:3000
